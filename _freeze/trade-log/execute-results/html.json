td>0.9091</td><td>-0.0081</td><td>0.0097</td></tr><tr><td>ml_hard_filter</td><td>8</td><td>7</td><td>1.2081</td><td>0.0226</td><td>0.8750</td><td>-0.0080</td><td>0.0083</td></tr><tr><td>ml_position_scaling</td><td>11</td><td>0</td><td>1.5665</td><td>0.0398</td><td>0.9091</td><td>-0.0094</td><td>0.0097</td></tr></tbody>\n    </table>\n  </div>\n</div>\n<script>\n(function() {\n  const table = document.getElementById(\"trade_log_overlay_comparison\");\n  const search = document.getElementById(\"trade_log_overlay_comparison_search\");\n  if (!table || !search) return;\n\n  search.addEventListener(\"input\", function() {\n    const query = search.value.toLowerCase();\n    Array.from(table.tBodies[0].rows).forEach(function(row) {\n      row.style.display = row.innerText.toLowerCase().includes(query) ? \"\" : \"none\";\n    });\n  });\n\n  Array.from(table.tHead.rows[0].cells).forEach(function(header, index) {\n    header.style.cursor = \"pointer\";\n    header.title = \"Click to sort\";\n    header.addEventListener(\"click\", function() {\n      const tbody = table.tBodies[0];\n      const currentDirection = header.getAttribute(\"data-sort\") === \"asc\" ? \"desc\" : \"asc\";\n      Array.from(table.tHead.rows[0].cells).forEach(function(cell) { cell.removeAttribute(\"data-sort\"); });\n      header.setAttribute(\"data-sort\", currentDirection);\n      const rows = Array.from(tbody.rows);\n      rows.sort(function(a, b) {\n        const av = a.cells[index].innerText.trim();\n        const bv = b.cells[index].innerText.trim();\n        const an = Number(av.replace(/[%,$]/g, \"\"));\n        const bn = Number(bv.replace(/[%,$]/g, \"\"));\n        const result = (!Number.isNaN(an) && !Number.isNaN(bn))\n          ? an - bn\n          : av.localeCompare(bv);\n        return currentDirection === \"asc\" ? result : -result;\n      });\n      rows.forEach(function(row) { tbody.appendChild(row); });\n    });\n  });\n})();\n</script>\n```\n:::\n:::\n\n\nThe final ML overlay keeps the same trade timestamps as the baseline and changes capital allocation rather than deleting all low-score trades. That is why the overlay comparison is best read as a portfolio-allocation enhancement, not as a second independent blotter.\n\n## Why The Trade Log Matters\n\nThe trade log makes the backtest auditable. It shows:\n\n- when entries and exits occurred\n- how long trades stayed open\n- whether exits came from success, stop-loss, timeout, or breakout failure\n- how profits and losses were distributed across trades\n- how the final ML overlay changes position sizing on top of those same breakout opportunities\n\n",
