\n    Array.from(table.tBodies[0].rows).forEach(function(row) {\n      row.style.display = row.innerText.toLowerCase().includes(query) ? \"\" : \"none\";\n    });\n  });\n\n  Array.from(table.tHead.rows[0].cells).forEach(function(header, index) {\n    header.style.cursor = \"pointer\";\n    header.title = \"Click to sort\";\n    header.addEventListener(\"click\", function() {\n      const tbody = table.tBodies[0];\n      const currentDirection = header.getAttribute(\"data-sort\") === \"asc\" ? \"desc\" : \"asc\";\n      Array.from(table.tHead.rows[0].cells).forEach(function(cell) { cell.removeAttribute(\"data-sort\"); });\n      header.setAttribute(\"data-sort\", currentDirection);\n      const rows = Array.from(tbody.rows);\n      rows.sort(function(a, b) {\n        const av = a.cells[index].innerText.trim();\n        const bv = b.cells[index].innerText.trim();\n        const an = Number(av.replace(/[%,$]/g, \"\"));\n        const bn = Number(bv.replace(/[%,$]/g, \"\"));\n        const result = (!Number.isNaN(an) && !Number.isNaN(bn))\n          ? an - bn\n          : av.localeCompare(bv);\n        return currentDirection === \"asc\" ? result : -result;\n      });\n      rows.forEach(function(row) { tbody.appendChild(row); });\n    });\n  });\n})();\n</script>\n```\n:::\n:::\n\n\n## Downloads\n\n::: {#ac01e82f .cell execution_count=2}\n\n::: {.cell-output .cell-output-display execution_count=2}\n```{=html}\n\n    <p><a href=\"downloads/trade_blotter.csv\" download>Download baseline trade blotter CSV</a></p>\n    <p><a href=\"downloads/ledger.csv\" download>Download baseline trade ledger CSV</a></p>\n    <p><a href=\"downloads/scaled_selected_asset_backtest_comparison.csv\" download>Download ML overlay comparison CSV</a></p>\n    <p><a href=\"downloads/scaled_selected_asset_backtest_summary.json\" download>Download ML overlay summary JSON</a></p>\n    \n```\n:::\n:::\n\n\n## Interactive Trade Return View\n\n::: {#e89ba921 .cell execution_count=3}\n\n::: {.cell-outpu